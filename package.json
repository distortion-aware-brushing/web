{
  "name": "@dabrush/web",
  "version": "0.1.0",
  "description": "Canvas and React web adapters for the DAB brushing engine.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dabrush/engine": "file:../dab-engine",
    "@dabrush/schema": "file:../dab-schema",
    "d3": "^7.9.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.20",
    "react": "^18.3.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.1"
  },
  "license": "MIT"
}
